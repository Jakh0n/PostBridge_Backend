# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb://127.0.0.1:27017/korea-parcel-marketplace

# Server port (Render sets PORT automatically)
PORT=5000

# Comma-separated allowed origins for CORS (e.g. http://localhost:3000,https://your-app.vercel.app)
CORS_ORIGIN=http://localhost:3000

# Optional: Node environment
NODE_ENV=development
